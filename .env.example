# Timezone
TZ=America/Sao_Paulo

# MySQL container
MYSQL_PORT=3306
MYSQL_DATABASE=painel_lojista
MYSQL_USER=painel_lojista
MYSQL_PASSWORD=CHANGE_ME_WITH_A_STRONG_DATABASE_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_WITH_A_DIFFERENT_STRONG_DATABASE_PASSWORD

# Adminer
ADMINER_PORT=8080

# Prisma / application
DATABASE_URL="mysql://painel_lojista:CHANGE_ME_WITH_A_STRONG_DATABASE_PASSWORD@localhost:3306/painel_lojista"
DATABASE_URL_DOCKER="mysql://painel_lojista:CHANGE_ME_WITH_A_STRONG_DATABASE_PASSWORD@mysql:3306/painel_lojista"
SHADOW_DATABASE_URL="mysql://root:CHANGE_ME_WITH_A_DIFFERENT_STRONG_DATABASE_PASSWORD@localhost:3306/prisma_migrate_shadow_db"
SHADOW_DATABASE_URL_DOCKER="mysql://root:CHANGE_ME_WITH_A_DIFFERENT_STRONG_DATABASE_PASSWORD@mysql:3306/prisma_migrate_shadow_db"

# Backend browser CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Receipt printer
RECEIPT_PRINTER_MODE=stdout
RECEIPT_PRINTER_HOST=
RECEIPT_PRINTER_PORT=9100
RECEIPT_PRINTER_TIMEOUT_MS=5000
