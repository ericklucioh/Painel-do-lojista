# Timezone
TZ=America/Sao_Paulo

# MySQL container
MYSQL_PORT=3306
MYSQL_DATABASE=painel_lojista
MYSQL_USER=painel_lojista
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# Adminer
ADMINER_PORT=8080

# Prisma / application
DATABASE_URL="mysql://painel_lojista:change-me@localhost:3306/painel_lojista"
DATABASE_URL_DOCKER="mysql://painel_lojista:change-me@mysql:3306/painel_lojista"
SHADOW_DATABASE_URL="mysql://root:change-me-root@localhost:3306/prisma_migrate_shadow_db"
SHADOW_DATABASE_URL_DOCKER="mysql://root:change-me-root@mysql:3306/prisma_migrate_shadow_db"

# Backend browser CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Receipt printer
RECEIPT_PRINTER_MODE=stdout
RECEIPT_PRINTER_HOST=
RECEIPT_PRINTER_PORT=9100
RECEIPT_PRINTER_TIMEOUT_MS=5000
