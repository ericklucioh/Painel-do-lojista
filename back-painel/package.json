{
    "name": "back-painel",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "prebuild": "npm run prisma:generate",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/server.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prisma:generate": "prisma generate --config prisma.config.ts",
        "prisma:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
        "prisma:seed": "node prisma/seed.mjs",
        "prisma:test:generate": "prisma generate --config prisma/test.config.ts",
        "prisma:test:reset": "node prisma/test/reset.mjs",
        "test": "npm run prisma:test:generate && npm run prisma:test:reset && vitest",
        "test:run": "npm run prisma:test:generate && npm run prisma:test:reset && vitest run",
        "test:watch": "npm run prisma:test:generate && npm run prisma:test:reset && vitest"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@prisma/adapter-better-sqlite3": "^7.8.0",
        "@prisma/adapter-mariadb": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "bcryptjs": "^3.0.3",
        "better-sqlite3": "^12.10.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.9.1",
        "@types/supertest": "^7.2.0",
        "eslint": "^9.39.4",
        "globals": "^16.4.0",
        "prettier": "^3.8.3",
        "prettier-plugin-prisma": "^5.0.0",
        "prisma": "^7.8.0",
        "supertest": "^7.2.2",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vitest": "^4.1.7"
    }
}
